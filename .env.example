# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# -------------------------------------------------------------------
# ServiceNow instance URL (optional — defaults to dev432501)
# -------------------------------------------------------------------
# SNOW_INSTANCE=https://dev432501.service-now.com

# -------------------------------------------------------------------
# API Key — preferred auth for PDI (no browser session needed)
# -------------------------------------------------------------------
# Setup: System Web Services > API Access Policies > REST API Key > New
# See servicenow-pdi-api-key-setup.md for the full walkthrough.
SNOW_API_KEY=
